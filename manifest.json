{
  "manifest_version": 3,
  "name": "CompressKit — Multi-Format Compression Tool",
  "version": "1.0.0",
  "description": "Compress and decompress Text, PNG, JPEG, WAV, and MP4 files directly in your browser with real-time metrics.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*",
        "*.js",
        "*.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
